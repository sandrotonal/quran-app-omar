<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_dark_navy"
    android:padding="16dp">

    <!-- Top Left: Mescid Icon / Title -->
    <TextView
        android:id="@+id/widget_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_alignParentStart="true"
        android:text="KUR'AN REHBERİ"
        android:textColor="#CCFFFFFF"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.1" />

    <!-- Top Right: Next Prayer Time Text -->
    <TextView
        android:id="@+id/widget_prayer_countdown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:text="AKŞAMA 1:42"
        android:textColor="#00E6A7"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        android:shadowColor="#4000E6A7"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="8" />

    <!-- Top Right (Under Prayer): Streak / Daily Activity (Duolingo Style) -->
    <TextView
        android:id="@+id/widget_streak"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/widget_prayer_countdown"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="6dp"
        android:text="1 🔥"
        android:textColor="#FFA500"
        android:background="@drawable/bg_streak_capsule"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:textSize="11sp"
        android:textStyle="bold"
        android:shadowColor="#33FFA500"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="4" />

    <!-- Center Content: Quote / Zikir / Surah -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_main_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kalpler ancak Allah'ı anmakla huzur bulur."
            android:textColor="#EFEFEF"
            android:textSize="14sp"
            android:gravity="center"
            android:textStyle="italic"
            android:maxLines="3"
            android:ellipsize="end"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/widget_sub_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rad 28"
            android:textColor="#8892B0"
            android:textSize="11sp"
            android:gravity="center"
            android:textAllCaps="true"
            android:letterSpacing="0.1" />
    </LinearLayout>

</RelativeLayout>
